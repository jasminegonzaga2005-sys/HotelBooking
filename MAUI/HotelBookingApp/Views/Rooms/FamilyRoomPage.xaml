<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="HotelBookingApp.Views.Rooms.FamilyRoomPage"
    Title="Family Room"
    BackgroundColor="#F5F7FA">

    <Grid RowDefinitions="*,Auto">

        <ScrollView>

            <VerticalStackLayout
                Padding="20"
                Spacing="20">

                <Label
                    Text="Family Room"
                    FontSize="28"
                    FontAttributes="Bold"
                    TextColor="#0F4C81"/>

                <Frame
                    HeightRequest="180"
                    BackgroundColor="#EAF2F8"
                    CornerRadius="15"
                    HasShadow="False">

                    <Label
                        Text="Room Image"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        TextColor="#0F4C81"/>

                </Frame>

                <Label
                    Text="Rate of ₱4,500 per night"
                    FontSize="20"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    TextColor="#0F4C81"/>

                <Frame
                    BackgroundColor="#EAF2F8"
                    CornerRadius="15"
                    HasShadow="False">

                    <VerticalStackLayout>

                        <Label
                            Text="Description"
                            FontAttributes="Bold"
                            TextColor="#0F4C81"/>

                        <Label
                            Text="Large room designed to comfortably accommodate families or groups with multiple beds and extra space."
                            TextColor="Black"/>

                    </VerticalStackLayout>

                </Frame>

                <Frame
                    BackgroundColor="#EAF2F8"
                    CornerRadius="15"
                    HasShadow="False">

                    <VerticalStackLayout
                        Spacing="8">

                        <Label
                            Text="Amenities"
                            FontAttributes="Bold"
                            TextColor="#0F4C81"/>

                        <Label Text="• 2 Queen Beds"
                               TextColor="Black"/>
                        <Label Text="• Air Conditioning"
                               TextColor="Black"/>
                        <Label Text="• Free Wi-Fi"
                               TextColor="Black"/>
                        <Label Text="• 55&quot; Smart TV"
                               TextColor="Black"/>
                        <Label Text="• Dining Table"
                               TextColor="Black"/>
                        <Label Text="• Sofa Area"
                               TextColor="Black"/>
                        <Label Text="• Mini Refrigerator"
                               TextColor="Black"/>
                        <Label Text="• Coffee Maker"
                               TextColor="Black"/>
                        <Label Text="• Safety Box"
                               TextColor="Black"/>
                        <Label Text="• Iron and Ironing Board"
                               TextColor="Black"/>
                        <Label Text="• Private Bathroom"
                               TextColor="Black"/>
                        <Label Text="• Hair Dryer"
                               TextColor="Black"/>
                        <Label Text="• Towels and Toiletries"
                               TextColor="Black"/>
                        <Label Text="• Complementary Bottled Water"
                               TextColor="Black"/>
                        <Label Text="• Free Breakfast (4)"
                               TextColor="Black"/>

                    </VerticalStackLayout>

                </Frame>

                

            </VerticalStackLayout>

        </ScrollView>

    </Grid>

</ContentPage>