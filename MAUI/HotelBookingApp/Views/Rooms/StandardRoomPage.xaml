<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="HotelBookingApp.Views.Rooms.StandardRoomPage"
    Title="Standard Room"
    BackgroundColor="#F5F7FA">

    <Grid RowDefinitions="*,Auto">

        <ScrollView>

            <VerticalStackLayout
                Padding="20"
                Spacing="20">

                <Label
                    Text="Standard Room"
                    FontSize="28"
                    FontAttributes="Bold"
                    TextColor="#0F4C81"/>

                <Frame
                    HeightRequest="180"
                    BackgroundColor="#EAF2F8"
                    CornerRadius="15"
                    HasShadow="False">

                    <Label
                        Text="Room Image"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        TextColor="#0F4C81"/>

                </Frame>

                <Frame
                    BackgroundColor="#EAF2F8"
                    CornerRadius="15"
                    HasShadow="False">

                    <VerticalStackLayout>

                        <Label
                            Text="Description"
                            FontAttributes="Bold"
                            TextColor="#0F4C81"/>

                        <Label
                            Text="Comfortable room with basic amenities, ideal for solo travelers or business guests."/>

                    </VerticalStackLayout>

                </Frame>

                <Frame
                    BackgroundColor="#EAF2F8"
                    CornerRadius="15"
                    HasShadow="False">

                    <VerticalStackLayout
                        Spacing="8">

                        <Label
                            Text="Amenities"
                            FontAttributes="Bold"
                            TextColor="#0F4C81"/>

                        <Label Text="• 1 Single Bed"/>
                        <Label Text="• Air Conditioning"/>
                        <Label Text="• Free Wi-Fi"/>
                        <Label Text="• 32&quot; Smart TV"/>
                        <Label Text="• Mini Fridge"/>
                        <Label Text="• Hair Dryer"/>
                        <Label Text="• Microwave"/>
                        <Label Text="• Work Desk"/>
                        <Label Text="• Private Bathroom"/>
                        <Label Text="• Towels and Toiletries"/>
                        <Label Text="• Complementary Bottled Water"/>

                    </VerticalStackLayout>

                </Frame>

                <Label
                    Text="₱1,500 / Night"
                    FontSize="20"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    TextColor="#0F4C81"/>

            </VerticalStackLayout>

        </ScrollView>

        <Frame
            Grid.Row="1"
            BackgroundColor="#EAF2F8"
            CornerRadius="16"
            Padding="15"
            HasShadow="False">

            <Grid
                ColumnDefinitions="*,*,*,*"
                ColumnSpacing="10">

                <Button
                    Grid.Column="0"
                    Text="Book&#10;Room"
                    HeightRequest="60"/>

                <Button
                    Grid.Column="1"
                    Text="My&#10;Bookings"
                    HeightRequest="60"/>

                <Button
                    Grid.Column="2"
                    Text="Home"
                    HeightRequest="60"/>

                <Button
                    Grid.Column="3"
                    Text="Profile"
                    HeightRequest="60"/>

            </Grid>

        </Frame>

    </Grid>

</ContentPage>