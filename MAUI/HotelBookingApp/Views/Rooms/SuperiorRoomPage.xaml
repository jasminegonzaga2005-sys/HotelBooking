<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="HotelBookingApp.Views.Rooms.SuperiorRoomPage"
    Title="Superior Room"
    BackgroundColor="#F5F7FA">

    <Grid RowDefinitions="*,Auto">

        <ScrollView>

            <VerticalStackLayout
                Padding="20"
                Spacing="20">

                <Label
                    Text="Superior Room"
                    FontSize="28"
                    FontAttributes="Bold"
                    TextColor="#0F4C81"/>

                <Frame
                    HeightRequest="180"
                    BackgroundColor="#EAF2F8"
                    CornerRadius="15"
                    HasShadow="False">

                    <Label
                        Text="Room Image"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        TextColor="#0F4C81"/>

                </Frame>

                <Frame
                    BackgroundColor="#EAF2F8"
                    CornerRadius="15"
                    HasShadow="False">

                    <VerticalStackLayout>

                        <Label
                            Text="Description"
                            FontAttributes="Bold"
                            TextColor="#0F4C81"/>

                        <Label
                            Text="Spacious room offering enhanced comfort and modern amenities for couples or leisure travelers."
                            TextColor="Black"/>

                    </VerticalStackLayout>

                </Frame>

                <Frame
                    BackgroundColor="#EAF2F8"
                    CornerRadius="15"
                    HasShadow="False">

                    <VerticalStackLayout
                        Spacing="8">

                        <Label
                            Text="Amenities"
                            FontAttributes="Bold"
                            TextColor="#0F4C81"/>

                        <Label Text="• 1 Queen Bed"
                               TextColor="Black"/>
                        <Label Text="• Air Conditioning"
                               TextColor="Black"/>
                        <Label Text="• Free Wi-Fi"
                               TextColor="Black"/>
                        <Label Text="• 43&quot; Smart TV"
                               TextColor="Black"/>
                        <Label Text="• Mini Fridge"
                               TextColor="Black"/>
                        <Label Text="• Coffee &amp; Tea Set"
                               TextColor="Black"/>
                        <Label Text="• Hair Dryer"
                               TextColor="Black"/>
                        <Label Text="• Microwave"
                               TextColor="Black"/>
                        <Label Text="• Work Desk"
                               TextColor="Black"/>
                        <Label Text="• Private Bathroom"
                               TextColor="Black"/>
                        <Label Text="• Towels and Toiletries"
                               TextColor="Black"/>
                        <Label Text="• Complementary Bottled Water"
                               TextColor="Black"/>

                    </VerticalStackLayout>

                </Frame>

                <Label
                    Text="₱2,300 / Night"
                    FontSize="20"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    TextColor="#0F4C81"/>

            </VerticalStackLayout>

        </ScrollView>

    </Grid>

</ContentPage>