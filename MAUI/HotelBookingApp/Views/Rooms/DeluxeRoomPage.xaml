<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="HotelBookingApp.Views.Rooms.DeluxeRoomPage"
    Title="Deluxe Room"
    BackgroundColor="#F5F7FA">

    <Grid RowDefinitions="*,Auto">

        <ScrollView>

            <VerticalStackLayout
                Padding="20"
                Spacing="20">

                <Label
                    Text="Deluxe Room"
                    FontSize="28"
                    FontAttributes="Bold"
                    TextColor="#0F4C81"/>

                <Frame
                    HeightRequest="180"
                    BackgroundColor="#EAF2F8"
                    CornerRadius="15"
                    HasShadow="False">

                    <Label
                        Text="Room Image"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        TextColor="#0F4C81"/>

                </Frame>

                <Label
                    Text="Rate of ₱3,200 per night"
                    FontSize="20"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    TextColor="#0F4C81"/>

                <Frame
                    BackgroundColor="#EAF2F8"
                    CornerRadius="15"
                    HasShadow="False">

                    <VerticalStackLayout>

                        <Label
                            Text="Description"
                            FontAttributes="Bold"
                            TextColor="#0F4C81"/>

                        <Label
                            Text="Premium room with upgraded furnishings and additional conveniences for a relaxing stay."
                            TextColor="Black"/>

                    </VerticalStackLayout>

                </Frame>

                <Frame
                    BackgroundColor="#EAF2F8"
                    CornerRadius="15"
                    HasShadow="False">

                    <VerticalStackLayout
                        Spacing="8">

                        <Label
                            Text="Amenities"
                            FontAttributes="Bold"
                            TextColor="#0F4C81"/>

                        <Label Text="• 1 King Bed / 2 Double Beds"
                               TextColor="Black"/>
                        <Label Text="• Air Conditioning"
                               TextColor="Black"/>
                        <Label Text="• Free Wi-Fi"
                               TextColor="Black"/>
                        <Label Text="• 50&quot; Smart TV"
                               TextColor="Black"/>
                        <Label Text="• Sofa Seating"
                               TextColor="Black"/>
                        <Label Text="• Coffee Maker"
                               TextColor="Black"/>
                        <Label Text="• Safety Box"
                               TextColor="Black"/>
                        <Label Text="• Iron and Ironing Board"
                               TextColor="Black"/>
                        <Label Text="• Private Bathroom"
                               TextColor="Black"/>
                        <Label Text="• Hair Dryer"
                               TextColor="Black"/>
                        <Label Text="• Towels and Toiletries"
                               TextColor="Black"/>
                        <Label Text="• Complementary Bottled Water"
                               TextColor="Black"/>
                        <Label Text="• Free Breakfast (2)"
                               TextColor="Black"/>

                    </VerticalStackLayout>

                </Frame>

                

            </VerticalStackLayout>

        </ScrollView>

    </Grid>

</ContentPage>