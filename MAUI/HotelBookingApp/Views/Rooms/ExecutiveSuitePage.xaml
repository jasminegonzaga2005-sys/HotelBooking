<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="HotelBookingApp.Views.Rooms.ExecutiveSuitePage"
    Title="Executive Suite"
    BackgroundColor="#F5F7FA">

    <Grid RowDefinitions="*,Auto">

        <ScrollView>

            <VerticalStackLayout
                Padding="20"
                Spacing="20">

                <Label
                    Text="Executive Suite"
                    FontSize="28"
                    FontAttributes="Bold"
                    TextColor="#0F4C81"/>

                <Frame
                    HeightRequest="180"
                    BackgroundColor="#EAF2F8"
                    CornerRadius="15"
                    HasShadow="False">

                    <Label
                        Text="Room Image"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        TextColor="#0F4C81"/>

                </Frame>

                <Frame
                    BackgroundColor="#EAF2F8"
                    CornerRadius="15"
                    HasShadow="False">

                    <VerticalStackLayout>

                        <Label
                            Text="Description"
                            FontAttributes="Bold"
                            TextColor="#0F4C81"/>

                        <Label
                            Text="Luxurious suite featuring separate living and sleeping areas with premium amenities and exclusive services."/>

                    </VerticalStackLayout>

                </Frame>

                <Frame
                    BackgroundColor="#EAF2F8"
                    CornerRadius="15"
                    HasShadow="False">

                    <VerticalStackLayout
                        Spacing="8">

                        <Label
                            Text="Amenities"
                            FontAttributes="Bold"
                            TextColor="#0F4C81"/>

                        <Label Text="• 1 King Bed"/>
                        <Label Text="• Separate Living Room"/>
                        <Label Text="• 65&quot; &amp; 50&quot; Smart TVs"/>
                        <Label Text="• Mini Bar"/>
                        <Label Text="• Bathtub &amp; Rain Shower"/>
                        <Label Text="• Towels and Toiletries"/>
                        <Label Text="• Safety Box"/>
                        <Label Text="• Iron and Ironing Board"/>
                        <Label Text="• Hair Dryer"/>
                        <Label Text="• Complementary Bottled Water"/>
                        <Label Text="• Welcome Fruit Basket"/>
                        <Label Text="• Complimentary Wi-Fi"/>
                        <Label Text="• Free Breakfast (2)"/>

                    </VerticalStackLayout>

                </Frame>

                <Label
                    Text="₱7,000 / Night"
                    FontSize="20"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    TextColor="#0F4C81"/>

            </VerticalStackLayout>

        </ScrollView>

        <Frame
            Grid.Row="1"
            BackgroundColor="#EAF2F8"
            CornerRadius="16"
            Padding="15"
            HasShadow="False">

            <Grid
                ColumnDefinitions="*,*,*,*"
                ColumnSpacing="10">

                <Button
                    Grid.Column="0"
                    Text="Book&#10;Room"
                    HeightRequest="60"/>

                <Button
                    Grid.Column="1"
                    Text="My&#10;Bookings"
                    HeightRequest="60"/>

                <Button
                    Grid.Column="2"
                    Text="Home"
                    HeightRequest="60"/>

                <Button
                    Grid.Column="3"
                    Text="Profile"
                    HeightRequest="60"/>

            </Grid>

        </Frame>

    </Grid>

</ContentPage>