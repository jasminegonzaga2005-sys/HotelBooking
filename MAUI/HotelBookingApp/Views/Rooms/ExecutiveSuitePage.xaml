<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="HotelBookingApp.Views.Rooms.ExecutiveSuitePage"
    Title="Executive Suite"
    BackgroundColor="#F5F7FA">

    <Grid RowDefinitions="*,Auto">

        <ScrollView>

            <VerticalStackLayout
                Padding="20"
                Spacing="20">

                <Label
                    Text="Executive Suite"
                    FontSize="28"
                    FontAttributes="Bold"
                    TextColor="#0F4C81"/>

                <Frame
                    HeightRequest="180"
                    BackgroundColor="#EAF2F8"
                    CornerRadius="15"
                    HasShadow="False">

                    <Label
                        Text="Room Image"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        TextColor="#0F4C81"/>

                </Frame>

                <Label
                    Text="Rate of ₱ 7,000 per night"
                    FontSize="20"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    TextColor="#0F4C81"/>       

                <Frame
                    BackgroundColor="#EAF2F8"
                    CornerRadius="15"
                    HasShadow="False">

                    <VerticalStackLayout>

                        <Label
                            Text="Description"
                            FontAttributes="Bold"
                            TextColor="#0F4C81"/>

                        <Label
                            Text="Luxurious suite featuring separate living and sleeping areas with premium amenities and exclusive services."
                            TextColor="Black"/>

                    </VerticalStackLayout>

                </Frame>

                <Frame
                    BackgroundColor="#EAF2F8"
                    CornerRadius="15"
                    HasShadow="False">

                    <VerticalStackLayout
                        Spacing="8">

                        <Label
                            Text="Amenities"
                            FontAttributes="Bold"
                            TextColor="#0F4C81"/>

                        <Label Text="• 1 King Bed"
                               TextColor="black"/>
                        <Label Text="• Separate Living Room"
                               TextColor="black"/>
                        <Label Text="• 65&quot; &amp; 50&quot; Smart TVs"
                               TextColor="black"/>
                        <Label Text="• Mini Bar"
                               TextColor="black"/>
                        <Label Text="• Bathtub &amp; Rain Shower"
                               TextColor="black"/>
                        <Label Text="• Towels and Toiletries"
                               TextColor="black"/>
                        <Label Text="• Safety Box"
                               TextColor="black"/>
                        <Label Text="• Iron and Ironing Board"
                               TextColor="black"/>
                        <Label Text="• Hair Dryer"
                               TextColor="black"/>
                        <Label Text="• Complementary Bottled Water"
                               TextColor="black"/>
                        <Label Text="• Welcome Fruit Basket"
                               TextColor="black"/>
                        <Label Text="• Complimentary Wi-Fi"
                               TextColor="black"/>
                        <Label Text="• Free Breakfast (2)"
                               TextColor="black"/>

                    </VerticalStackLayout>

                </Frame>

               

            </VerticalStackLayout>

        </ScrollView>

    </Grid>

</ContentPage>