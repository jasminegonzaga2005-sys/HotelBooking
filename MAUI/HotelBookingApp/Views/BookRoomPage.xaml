<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="HotelBookingApp.Views.BookRoomPage"
    Title="Book a Room"
    BackgroundColor="#F5F7FA">


    <Grid RowDefinitions="*,Auto">


        <ScrollView Grid.Row="0">

            <VerticalStackLayout
                Padding="20,30"
                Spacing="20"
                MaximumWidthRequest="420"
                HorizontalOptions="Center">


                <!-- Title -->
                <Label
                    Text="Book a Room"
                    FontSize="30"
                    FontAttributes="Bold"
                    TextColor="#0F4C81" />


                <!-- Available Rooms -->
                <Frame
                    CornerRadius="15"
                    Padding="20"
                    BorderColor="#D8E2EC"
                    BackgroundColor="White"
                    HasShadow="False">


                    <VerticalStackLayout Spacing="12">


                        <Label
                            Text="Available Rooms"
                            FontSize="22"
                            FontAttributes="Bold"
                            TextColor="#0F4C81" />



                        <!-- Column Headers -->
                        <Grid
                            ColumnDefinitions="*,*"
                            Padding="15,10"
                            BackgroundColor="#EAF2F8">


                            <Label
                                Text="Room Number"
                                FontAttributes="Bold"
                                TextColor="#0F4C81" />


                            <Label
                                Grid.Column="1"
                                Text="Room Type"
                                FontAttributes="Bold"
                                TextColor="#0F4C81" />


                        </Grid>




                        <!-- Room List -->
                        <CollectionView
                            HeightRequest="300"
                            ItemsSource="{Binding AvailableRooms}"
                            SelectionMode="None">


                            <CollectionView.ItemTemplate>

                                <DataTemplate>


                                    <Frame
                                        Margin="0,3"
                                        Padding="15"
                                        CornerRadius="10"
                                        BorderColor="#D8E2EC"
                                        BackgroundColor="White"
                                        HasShadow="False">


                                        <Grid ColumnDefinitions="*,*">


                                            <Grid.GestureRecognizers>

                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectRoomCommand}"
                                                    CommandParameter="{Binding .}" />

                                            </Grid.GestureRecognizers>



                                            <Label
                                                Text="{Binding RoomNum}"
                                                FontSize="16"
                                                FontAttributes="Bold"
                                                TextColor="#0F4C81"
                                                VerticalOptions="Center" />



                                            <Label
                                                Grid.Column="1"
                                                Text="{Binding RoomType.RoomTypeName}"
                                                FontSize="16"
                                                TextColor="#444"
                                                VerticalOptions="Center" />


                                        </Grid>


                                    </Frame>


                                </DataTemplate>


                            </CollectionView.ItemTemplate>


                        </CollectionView>



                        <!-- Selected Room -->
                        <Frame
                            Margin="0,10,0,0"
                            Padding="15"
                            CornerRadius="10"
                            BorderColor="#D8E2EC"
                            BackgroundColor="#EAF2F8"
                            HasShadow="False">


                            <VerticalStackLayout Spacing="5">


                                <Label
                                    Text="Selected Room"
                                    FontSize="18"
                                    FontAttributes="Bold"
                                    TextColor="#0F4C81" />



                                <Label
                                    Text="{Binding SelectedRoom.RoomNum, StringFormat='Room Number: {0}'}"
                                    TextColor="#444" />



                                <Label
                                    Text="{Binding SelectedRoom.RoomType.RoomTypeName, StringFormat='Room Type: {0}'}"
                                    TextColor="#444" />


                            </VerticalStackLayout>


                        </Frame>


                    </VerticalStackLayout>


                </Frame>





                <!-- Booking Details -->
                <Frame
                    CornerRadius="15"
                    Padding="20"
                    BorderColor="#D8E2EC"
                    BackgroundColor="White"
                    HasShadow="False">


                    <VerticalStackLayout Spacing="15">


                        <Label
                            Text="Booking Details"
                            FontSize="22"
                            FontAttributes="Bold"
                            TextColor="#0F4C81" />



                        <Label
                            Text="Check-in Date"
                            FontAttributes="Bold"
                            TextColor="#0F4C81" />


                        <DatePicker
                            HeightRequest="45"
                            Date="{Binding CheckInDate}" />



                        <Label
                            Text="Check-out Date"
                            FontAttributes="Bold"
                            TextColor="#0F4C81" />


                        <DatePicker
                            HeightRequest="45"
                            Date="{Binding CheckOutDate}" />



                        <Label
                            Text="Guests"
                            FontAttributes="Bold"
                            TextColor="#0F4C81" />



                        <Entry
                            Placeholder="Enter number of guests"
                            Keyboard="Numeric"
                            HeightRequest="45"
                            BackgroundColor="#F8FAFC"
                            Text="{Binding Guests}" />


                    </VerticalStackLayout>


                </Frame>





                <!-- Book Button -->
                <Button
                    Text="Book Now"
                    HeightRequest="50"
                    CornerRadius="10"
                    FontSize="16"
                    BackgroundColor="#0F4C81"
                    TextColor="White"
                    Command="{Binding BookRoomCommand}" />



            </VerticalStackLayout>


        </ScrollView>





        <!-- Bottom Navigation -->
        <Grid
            Grid.Row="1"
            Padding="15"
            BackgroundColor="#EAF2F8"
            ColumnDefinitions="*,*,*,*"
            ColumnSpacing="10">



            <Button
                Grid.Column="0"
                Text="Book&#10;Room"
                HeightRequest="60"
                CornerRadius="10"
                BackgroundColor="#0F4C81"
                TextColor="White" />



            <Button
                Grid.Column="1"
                Text="My&#10;Bookings"
                HeightRequest="60"
                CornerRadius="10"
                BackgroundColor="White"
                TextColor="#0F4C81" />



            <Button
                Grid.Column="2"
                Text="Home"
                HeightRequest="60"
                CornerRadius="10"
                BackgroundColor="White"
                TextColor="#0F4C81" />



            <Button
                Grid.Column="3"
                Text="Profile"
                HeightRequest="60"
                CornerRadius="10"
                BackgroundColor="White"
                TextColor="#0F4C81" />


        </Grid>


    </Grid>


</ContentPage>