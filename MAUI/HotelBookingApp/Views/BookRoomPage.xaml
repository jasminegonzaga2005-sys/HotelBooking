<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HotelBookingApp.Views.BookRoomPage"
             BackgroundColor="#F5F7FA"
             Title="Book a Room">

    <!-- Root Grid: Top scrollable view + Bottom navigation bar -->
    <Grid RowDefinitions="*, Auto">

        <!-- Scrollable Form Container -->
        <ScrollView Grid.Row="0" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="20,30" 
                                 Spacing="20" 
                                 MaximumWidthRequest="420" 
                                 HorizontalOptions="Center">

                <!-- Main Title -->
                <Label Text="Book a Room" 
                       FontSize="30" 
                       FontAttributes="Bold" 
                       TextColor="#0F4C81" />

                <!-- Section 1: Room Selection Card -->
                <Frame CornerRadius="15" 
                       Padding="20" 
                       BorderColor="#D8E2EC" 
                       BackgroundColor="White" 
                       HasShadow="False">

                    <VerticalStackLayout Spacing="15">
                        <Label Text="Select Room Type" 
                               FontSize="22" 
                               FontAttributes="Bold" 
                               TextColor="#0F4C81" />

                        <!-- Room Type Picker -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Room Type" 
                                   FontAttributes="Bold" 
                                   TextColor="#0F4C81" />
                            <Border Stroke="#D8E2EC" StrokeShape="RoundRectangle 8" HeightRequest="40">
                                <Picker Title="Select Room Type" 
                                        BackgroundColor="#F8FAFC" 
                                        TextColor="#1F2937"
                                        ItemsSource="{Binding RoomTypes}"
                                        ItemDisplayBinding="{Binding RoomTypeName}"
                                        SelectedItem="{Binding SelectedRoomType, Mode=TwoWay}">
                                    
                                </Picker>   
                            </Border>
                        </VerticalStackLayout>

                        <Label Text="{Binding SelectedRoomType.RoomTypeName, StringFormat='Chosen room: {0}'}"
                           TextColor="#0F4C81"
                           FontAttributes="Bold"
                           HorizontalOptions="Center" />

                        <!-- Available Rooms Display -->
                        <Border Stroke="#D8E2EC" StrokeShape="RoundRectangle 12" BackgroundColor="White" HeightRequest="250">
                            <CollectionView ItemsSource="{Binding FilteredRooms}">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="*, Auto" Padding="18,15">
                                            <Label Grid.Column="0" Text="{Binding RoomID}" FontAttributes="None" TextColor="#0F4C81" />
                                            <Label Grid.Column="1" Text="{Binding RoomType.RoomTypeName}" />
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </Border>


                        <!-- Room ID Input -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Enter Room ID" 
                                   FontAttributes="Bold" 
                                   TextColor="#0F4C81" />
                            <Border Stroke="#D8E2EC" StrokeShape="RoundRectangle 8" HeightRequest="45">
                                <Entry Keyboard="Numeric" 
                                       Placeholder="Example: 101" 
                                       BackgroundColor="#F8FAFC" 
                                       TextColor="#1F2937"
                                       Text="{Binding RoomIdInput, Mode=TwoWay}"/>
                            </Border>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Frame>

                <!-- Section 2: Booking Details Card -->
                <Frame CornerRadius="15" 
                       Padding="20" 
                       BorderColor="#D8E2EC" 
                       BackgroundColor="White" 
                       HasShadow="False">

                    <VerticalStackLayout Spacing="15">
                        <Label Text="Booking Details" 
                               FontSize="22" 
                               FontAttributes="Bold" 
                               TextColor="#0F4C81" />

                        <!-- Check-in Date -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Check-in Date" 
                                   FontAttributes="Bold" 
                                   TextColor="#0F4C81" />
                            <Border Stroke="#D8E2EC" StrokeShape="RoundRectangle 8" HeightRequest="45">
                                <DatePicker BackgroundColor="#F8FAFC" TextColor="#1F2937" 
                                            Date="{Binding CheckInDate}"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Check-out Date -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Check-out Date" 
                                   FontAttributes="Bold" 
                                   TextColor="#0F4C81" />
                            <Border Stroke="#D8E2EC" StrokeShape="RoundRectangle 8" HeightRequest="45">
                                <DatePicker BackgroundColor="#F8FAFC" TextColor="#1F2937" 
                                            Date="{Binding CheckOutDate}"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Guests Count -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Guests" 
                                   FontAttributes="Bold" 
                                   TextColor="#0F4C81" />
                            <Border Stroke="#D8E2EC" StrokeShape="RoundRectangle 8" HeightRequest="45">
                                <Entry Keyboard="Numeric" 
                                       Placeholder="Enter number of guests" 
                                       BackgroundColor="#F8FAFC" 
                                       TextColor="#1F2937" 
                                       Text="{Binding Guests}"/>
                            </Border>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Frame>

                <!-- Book Now Button -->
                <Button Text="Book Now" 
                        Command="{Binding BookRoomCommand}"
                        HeightRequest="50" 
                        CornerRadius="10" 
                        FontSize="16" 
                        FontAttributes="Bold"
                        BackgroundColor="#0F4C81" 
                        TextColor="White" />

            </VerticalStackLayout>
        </ScrollView>

        

    </Grid>
</ContentPage>