<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="HotelBookingApp.Views.BookRoomPage"
    Title="Book a Room"
    BackgroundColor="#F5F7FA">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">

            <VerticalStackLayout
                Padding="20,30"
                Spacing="20"
                MaximumWidthRequest="420"
                HorizontalOptions="Center">

                <Label
                    Text="Book a Room"
                    FontSize="30"
                    FontAttributes="Bold"
                    TextColor="#0F4C81"/>

                <!-- Frame 1: Room Selection -->
                <Frame
                    CornerRadius="15"
                    Padding="20"
                    BorderColor="#D8E2EC"
                    BackgroundColor="White"
                    HasShadow="False">

                    <VerticalStackLayout Spacing="15">

                        <Label
                            Text="Select Room Type"
                            FontSize="22"
                            FontAttributes="Bold"
                            TextColor="#0F4C81"/>

                        <Label
                            Text="Room Type"
                            FontAttributes="Bold"
                            TextColor="#0F4C81"/>

                        <Picker
                            x:Name="roomType"
                            Title="Choose Room Type"
                            HeightRequest="45"
                            BackgroundColor="#F8FAFC">
                            <Picker.Items>
                                <x:String>Standard Room — ₱1,500/night</x:String>
                                <x:String>Superior Room — ₱2,200/night</x:String>
                                <x:String>Deluxe Room — ₱3,200/night</x:String>
                                <x:String>Family Room — ₱4,000/night</x:String>
                                <x:String>Executive Suite — ₱5,500/night</x:String>
                            </Picker.Items>
                        </Picker>

                        <Label
                            x:Name="roomDesc"
                            TextColor="#5A7692"
                            FontSize="14"
                            LineHeight="1.4"/>

                        <VerticalStackLayout x:Name="roomFeatures" Spacing="6" Padding="0"/>

                        <Label
                            Text="Available Rooms"
                            FontAttributes="Bold"
                            TextColor="#0F4C81"/>

                        <Frame
                            Padding="0"
                            CornerRadius="12"
                            BorderColor="#D8E2EC"
                            BackgroundColor="White"
                            HasShadow="False">

                            <VerticalStackLayout x:Name="roomList" Spacing="0"/>

                        </Frame>

                        <Label
                            Text="Enter Room ID"
                            FontAttributes="Bold"
                            TextColor="#0F4C81"/>

                        <Entry
                            x:Name="roomId"
                            Placeholder="Example: 101"
                            Keyboard="Numeric"
                            HeightRequest="45"
                            BackgroundColor="#F8FAFC"/>

                    </VerticalStackLayout>

                </Frame>

                <!-- Frame 2: Booking Details -->
                <Frame
                    CornerRadius="15"
                    Padding="20"
                    BorderColor="#D8E2EC"
                    BackgroundColor="White"
                    HasShadow="False">

                    <VerticalStackLayout Spacing="15">

                        <Label
                            Text="Booking Details"
                            FontSize="22"
                            FontAttributes="Bold"
                            TextColor="#0F4C81"/>

                        <Label
                            Text="Check-in Date"
                            FontAttributes="Bold"
                            TextColor="#0F4C81"/>

                        <DatePicker x:Name="checkIn" HeightRequest="45"/>

                        <Label
                            Text="Check-out Date"
                            FontAttributes="Bold"
                            TextColor="#0F4C81"/>

                        <DatePicker x:Name="checkOut" HeightRequest="45"/>

                        <Label
                            Text="Guests"
                            FontAttributes="Bold"
                            TextColor="#0F4C81"/>

                        <Entry
                            x:Name="guests"
                            Text="1"
                            Placeholder="Enter number of guests"
                            Keyboard="Numeric"
                            HeightRequest="45"
                            BackgroundColor="#F8FAFC"/>

                        <Label
                            x:Name="guestLimitHint"
                            TextColor="#5A7692"
                            FontSize="14"/>

                        <Label
                            x:Name="guestWarning"
                            TextColor="#C0392B"
                            FontAttributes="Bold"
                            FontSize="13"/>

                    </VerticalStackLayout>

                </Frame>

                <!-- Frame 3: Amenities Selection -->
                <Frame
                    CornerRadius="15"
                    Padding="20"
                    BorderColor="#D8E2EC"
                    BackgroundColor="White"
                    HasShadow="False">

                    <VerticalStackLayout Spacing="15">

                        <Label
                            Text="Type to Add Amenities"
                            FontSize="22"
                            FontAttributes="Bold"
                            TextColor="#0F4C81"/>

                        <Entry
                            x:Name="amenitySearch"
                            Placeholder="breakfast buffet, extra bed etc.."
                            HeightRequest="45"
                            BackgroundColor="#E9EDF1"
                            TextColor="#1B2733"/>

                        <Label
                            Text="Amenities"
                            FontAttributes="Bold"
                            TextColor="#0F4C81"/>

                        <Frame
                            Padding="0"
                            CornerRadius="12"
                            BorderColor="#D8E2EC"
                            BackgroundColor="White"
                            HasShadow="False">

                            <VerticalStackLayout x:Name="amenityList" Spacing="0"/>

                        </Frame>

                        <Button
                            x:Name="addAmenitiesBtn"
                            Text="Add Amenities"
                            HeightRequest="48"
                            CornerRadius="10"
                            FontSize="15"
                            FontAttributes="Bold"
                            BackgroundColor="#E9EDF1"
                            TextColor="#3C5A76"
                            IsEnabled="False"/>

                        <FlexLayout
                            x:Name="selectedChips"
                            Wrap="Wrap"
                            Direction="Row"
                            JustifyContent="Start"
                            AlignItems="Start"
                            AlignContent="Start"/>

                    </VerticalStackLayout>

                </Frame>

                <!-- Frame 4: Summary Pricing -->
                <Frame
                    CornerRadius="15"
                    Padding="20"
                    BorderColor="#D8E2EC"
                    BackgroundColor="White"
                    HasShadow="False">

                    <VerticalStackLayout Spacing="15">

                        <Label
                            Text="Summary"
                            FontSize="22"
                            FontAttributes="Bold"
                            TextColor="#0F4C81"/>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label x:Name="roomLine" Text="Room (0 nights)" TextColor="#3C5A76" FontSize="14"/>
                            <Label x:Name="roomCost" Grid.Column="1" Text="₱0" TextColor="#3C5A76" FontSize="14" HorizontalOptions="End"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Amenities" TextColor="#3C5A76" FontSize="14"/>
                            <Label x:Name="amenityCost" Grid.Column="1" Text="₱0" TextColor="#3C5A76" FontSize="14" HorizontalOptions="End"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#E8EEF5"/>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Total" TextColor="#0F4C81" FontAttributes="Bold" FontSize="18"/>
                            <Label x:Name="totalCost" Grid.Column="1" Text="₱0" TextColor="#0F4C81" FontAttributes="Bold" FontSize="18" HorizontalOptions="End"/>
                        </Grid>

                    </VerticalStackLayout>

                </Frame>

                <Button
                    x:Name="bookBtn"
                    Text="Book Now"
                    HeightRequest="50"
                    CornerRadius="10"
                    FontSize="16"
                    BackgroundColor="#0F4C81"
                    TextColor="White"/>

            </VerticalStackLayout>

        </ScrollView>

        <Grid
            Grid.Row="1"
            Padding="15"
            BackgroundColor="#EAF2F8"
            ColumnSpacing="10"
            ColumnDefinitions="*,*,*,*">

            <Button
                Grid.Column="0"
                Text="Book&#10;Room"
                HeightRequest="60"
                CornerRadius="10"
                BackgroundColor="#0F4C81"
                TextColor="White"/>

            <Button
                Grid.Column="1"
                Text="My&#10;Bookings"
                HeightRequest="60"
                CornerRadius="10"
                BackgroundColor="White"
                TextColor="#0F4C81"/>

            <Button
                Grid.Column="2"
                Text="Home"
                HeightRequest="60"
                CornerRadius="10"
                BackgroundColor="White"
                TextColor="#0F4C81"/>

            <Button
                Grid.Column="3"
                Text="Profile"
                HeightRequest="60"
                CornerRadius="10"
                BackgroundColor="White"
                TextColor="#0F4C81"/>

        </Grid>

    </Grid>

</ContentPage>