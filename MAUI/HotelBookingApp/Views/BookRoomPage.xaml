<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HotelBookingApp.Views.BookRoomPage"
             BackgroundColor="#F5F7FA"
             Title="Book a Room">

    <!-- Root Grid: Top scrollable view + Bottom navigation bar -->
    <Grid RowDefinitions="*, Auto">

        <!-- Scrollable Form Container -->
        <ScrollView Grid.Row="0" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="20,30" 
                                 Spacing="20" 
                                 MaximumWidthRequest="420" 
                                 HorizontalOptions="Center">

                <!-- Main Title -->
                <Label Text="Book a Room" 
                       FontSize="30" 
                       FontAttributes="Bold" 
                       TextColor="#0F4C81" />

                <!-- Section 1: Room Selection Card -->
                <Frame CornerRadius="15" 
                       Padding="20" 
                       BorderColor="#D8E2EC" 
                       BackgroundColor="White" 
                       HasShadow="False">

                    <VerticalStackLayout Spacing="15">
                        <Label Text="Select Room Type" 
                               FontSize="22" 
                               FontAttributes="Bold" 
                               TextColor="#0F4C81" />

                        <!-- Room Type Picker -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Room Type" 
                                   FontAttributes="Bold" 
                                   TextColor="#0F4C81" />
                            <Border Stroke="#D8E2EC" StrokeShape="RoundRectangle 8" HeightRequest="45">
                                <Picker Title="Select Room Type" 
                                        BackgroundColor="#F8FAFC" 
                                        TextColor="#1F2937">
                                    <Picker.ItemsSource>
                                        <x:Array Type="{x:Type x:String}">
                                            <x:String>Standard Room — ₱1,500/night</x:String>
                                            <x:String>Superior Room — ₱2,200/night</x:String>
                                            <x:String>Deluxe Room — ₱3,200/night</x:String>
                                            <x:String>Family Room — ₱4,000/night</x:String>
                                            <x:String>Executive Suite — ₱5,500/night</x:String>
                                        </x:Array>
                                    </Picker.ItemsSource>
                                </Picker>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Available Rooms List Box -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Available Rooms" 
                                   FontAttributes="Bold" 
                                   TextColor="#0F4C81" />

                            <Border Stroke="#D8E2EC" 
                                    StrokeShape="RoundRectangle 12" 
                                    BackgroundColor="White">
                                <VerticalStackLayout>
                                    <!-- Room 101 -->
                                    <Grid ColumnDefinitions="*, Auto" Padding="18,15">
                                        <Label Grid.Column="0" Text="101" FontAttributes="Bold" FontSize="17" TextColor="#0F4C81" VerticalOptions="Center" />
                                        <Label Grid.Column="1" Text="Room 101" TextColor="#1F2937" VerticalOptions="Center" />
                                    </Grid>
                                    <BoxView HeightRequest="1" Color="#E8EEF5" />

                                    <!-- Room 102 -->
                                    <Grid ColumnDefinitions="*, Auto" Padding="18,15">
                                        <Label Grid.Column="0" Text="102" FontAttributes="Bold" FontSize="17" TextColor="#0F4C81" VerticalOptions="Center" />
                                        <Label Grid.Column="1" Text="Room 102" TextColor="#1F2937" VerticalOptions="Center" />
                                    </Grid>
                                    <BoxView HeightRequest="1" Color="#E8EEF5" />

                                    <!-- Room 103 -->
                                    <Grid ColumnDefinitions="*, Auto" Padding="18,15">
                                        <Label Grid.Column="0" Text="103" FontAttributes="Bold" FontSize="17" TextColor="#0F4C81" VerticalOptions="Center" />
                                        <Label Grid.Column="1" Text="Room 103" TextColor="#1F2937" VerticalOptions="Center" />
                                    </Grid>
                                    <BoxView HeightRequest="1" Color="#E8EEF5" />

                                    <!-- Room 104 -->
                                    <Grid ColumnDefinitions="*, Auto" Padding="18,15">
                                        <Label Grid.Column="0" Text="104" FontAttributes="Bold" FontSize="17" TextColor="#0F4C81" VerticalOptions="Center" />
                                        <Label Grid.Column="1" Text="Room 104" TextColor="#1F2937" VerticalOptions="Center" />
                                    </Grid>
                                    <BoxView HeightRequest="1" Color="#E8EEF5" />

                                    <!-- Room 105 -->
                                    <Grid ColumnDefinitions="*, Auto" Padding="18,15">
                                        <Label Grid.Column="0" Text="105" FontAttributes="Bold" FontSize="17" TextColor="#0F4C81" VerticalOptions="Center" />
                                        <Label Grid.Column="1" Text="Room 105" TextColor="#1F2937" VerticalOptions="Center" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Room ID Input -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Enter Room ID" 
                                   FontAttributes="Bold" 
                                   TextColor="#0F4C81" />
                            <Border Stroke="#D8E2EC" StrokeShape="RoundRectangle 8" HeightRequest="45">
                                <Entry Keyboard="Numeric" 
                                       Placeholder="Example: 101" 
                                       BackgroundColor="#F8FAFC" 
                                       TextColor="#1F2937" />
                            </Border>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Frame>

                <!-- Section 2: Booking Details Card -->
                <Frame CornerRadius="15" 
                       Padding="20" 
                       BorderColor="#D8E2EC" 
                       BackgroundColor="White" 
                       HasShadow="False">

                    <VerticalStackLayout Spacing="15">
                        <Label Text="Booking Details" 
                               FontSize="22" 
                               FontAttributes="Bold" 
                               TextColor="#0F4C81" />

                        <!-- Check-in Date -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Check-in Date" 
                                   FontAttributes="Bold" 
                                   TextColor="#0F4C81" />
                            <Border Stroke="#D8E2EC" StrokeShape="RoundRectangle 8" HeightRequest="45">
                                <DatePicker BackgroundColor="#F8FAFC" TextColor="#1F2937" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Check-out Date -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Check-out Date" 
                                   FontAttributes="Bold" 
                                   TextColor="#0F4C81" />
                            <Border Stroke="#D8E2EC" StrokeShape="RoundRectangle 8" HeightRequest="45">
                                <DatePicker BackgroundColor="#F8FAFC" TextColor="#1F2937" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Guests Count -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Guests" 
                                   FontAttributes="Bold" 
                                   TextColor="#0F4C81" />
                            <Border Stroke="#D8E2EC" StrokeShape="RoundRectangle 8" HeightRequest="45">
                                <Entry Keyboard="Numeric" 
                                       Placeholder="Enter number of guests" 
                                       BackgroundColor="#F8FAFC" 
                                       TextColor="#1F2937" />
                            </Border>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Frame>

                <!-- Book Now Button -->
                <Button Text="Book Now" 
                        HeightRequest="50" 
                        CornerRadius="10" 
                        FontSize="16" 
                        FontAttributes="Bold"
                        BackgroundColor="#0F4C81" 
                        TextColor="White" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Navigation Bar (3 items) -->
        <Grid Grid.Row="1" 
              ColumnDefinitions="*, *, *" 
              Padding="15" 
              ColumnSpacing="10" 
              BackgroundColor="#EAF2F8">

            <Button Grid.Column="0" 
                    Text="Book&#10;Room" 
                    HeightRequest="60" 
                    CornerRadius="10" 
                    BackgroundColor="#0F4C81" 
                    TextColor="White" 
                    FontSize="12" />

            <Button Grid.Column="1" 
                    Text="My&#10;Bookings" 
                    HeightRequest="60" 
                    CornerRadius="10" 
                    BackgroundColor="White" 
                    TextColor="#0F4C81" 
                    FontSize="12" />

            <Button Grid.Column="2" 
                    Text="Home" 
                    HeightRequest="60" 
                    CornerRadius="10" 
                    BackgroundColor="White" 
                    TextColor="#0F4C81" 
                    FontSize="12" />
        </Grid>

    </Grid>
</ContentPage>