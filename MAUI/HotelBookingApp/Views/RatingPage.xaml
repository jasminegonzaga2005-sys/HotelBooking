<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HotelBookingApp.Views.RatingPage"
             BackgroundColor="#D6D9DC">

    <ContentPage.Resources>
        <!-- Custom Colors from CSS Properties -->
        <Color x:Key="BgOuter">#EAF2F8</Color>
        <Color x:Key="CardBg">#FFFFFF</Color>
        <Color x:Key="Primary">#0F4C81</Color>
        <Color x:Key="AccentOrange">#E67E22</Color>
        <Color x:Key="TextMuted">#7A8B99</Color>
        <Color x:Key="InputBg">#EAF2F8</Color>
        <Color x:Key="InputBorder">#CBD9E3</Color>
        <Color x:Key="ButtonBg">#0F4C81</Color>
        <Color x:Key="ButtonText">#FFFFFF</Color>
    </ContentPage.Resources>

    <!-- Outer Body Centering Container -->
    <ScrollView VerticalOptions="Center" HorizontalOptions="Center">

        <!-- phone-frame -->
        <Border WidthRequest="340"
                BackgroundColor="{StaticResource BgOuter}"
                StrokeShape="RoundRectangle 20"
                Padding="16"
                Margin="20"
                StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="{StaticResource Primary}" Offset="0,10" Radius="30" Opacity="0.15" />
            </Border.Shadow>

            <!-- card -->
            <Border BackgroundColor="{StaticResource CardBg}"
                    StrokeShape="RoundRectangle 16"
                    Padding="24, 28"
                    StrokeThickness="0">
                <Border.Shadow>
                    <Shadow Brush="{StaticResource Primary}" Offset="0,4" Radius="14" Opacity="0.08" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="0">

                    <!-- hotel-name -->
                    <Label Text="Hotel Name"
                           TextColor="{StaticResource Primary}"
                           FontSize="22"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           Margin="0,0,0,16" />

                    <!-- rating-row -->
                    <Grid ColumnDefinitions="Auto, Auto, Auto, *" 
                          VerticalOptions="End" 
                          Margin="0,0,0,20">

                        <Label Grid.Column="0" 
                               Text="4/5" 
                               TextColor="{StaticResource AccentOrange}" 
                               FontAttributes="Bold" 
                               FontSize="15" 
                               Margin="0,0,8,0" />

                        <Label Grid.Column="1" 
                               Text="Rating" 
                               TextColor="{StaticResource Primary}" 
                               FontAttributes="None" 
                               FontSize="14" 
                               Margin="0,0,8,0" />

                        <Label Grid.Column="2" 
                               Text="33 reviews" 
                               TextColor="{StaticResource TextMuted}" 
                               FontSize="12" />

                        <!-- view-reviews-link -->
                        <Label Grid.Column="3" 
                               Text="View Reviews →" 
                               TextColor="{StaticResource Primary}" 
                               FontAttributes="Bold" 
                               FontSize="12" 
                               HorizontalOptions="End" 
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ViewReviewsCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <!-- field-label 1 -->
                    <Label Text="Rate the hotel based on your experience:"
                           TextColor="{StaticResource Primary}"
                           FontSize="14"
                           FontAttributes="None"
                           Margin="0,0,0,6" />

                    <!-- rating-input -->
                    <Border BackgroundColor="{StaticResource InputBg}"
                            Stroke="{StaticResource InputBorder}"
                            StrokeShape="RoundRectangle 8"
                            StrokeThickness="1"
                            Margin="0,0,0,18"
                            Padding="12,0">
                        <Entry Placeholder="Rating 1-15"
                               Keyboard="Numeric"
                               TextColor="#333333"
                               FontSize="14" />
                    </Border>

                    <!-- field-label 2 -->
                    <Label Text="Provide your feedback in below:"
                           TextColor="{StaticResource Primary}"
                           FontSize="14"
                           FontAttributes="None"
                           Margin="0,0,0,6" />

                    <!-- feedback-box -->
                    <Border BackgroundColor="{StaticResource InputBg}"
                            Stroke="{StaticResource InputBorder}"
                            StrokeShape="RoundRectangle 8"
                            StrokeThickness="1"
                            HeightRequest="80"
                            Margin="0,0,0,20"
                            Padding="12,4">
                        <Editor Placeholder="Write your feedback here..."
                                AutoSize="Disabled"
                                TextColor="#333333"
                                FontSize="14" />
                    </Border>

                    <!-- submit-btn -->
                    <Button Text="Submit"
                            BackgroundColor="{StaticResource ButtonBg}"
                            TextColor="{StaticResource ButtonText}"
                            FontSize="15"
                            FontAttributes="Bold"
                            CornerRadius="10"
                            HeightRequest="48"
                            Padding="12" />

                </VerticalStackLayout>
            </Border>
        </Border>
    </ScrollView>
</ContentPage>