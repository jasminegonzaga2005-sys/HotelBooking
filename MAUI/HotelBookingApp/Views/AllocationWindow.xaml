<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HotelBookingApp.Views.AllocationWindow"
             Title="Allocation Window"
             BackgroundColor="#F5F9FC">

    <ContentPage.Resources>
        <Color x:Key="ThemePrimary">#0F4C81</Color>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto" Margin="16">

        <!-- ================= SYSTEM HEADER ================= -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <VerticalStackLayout Grid.Column="0">
                <HorizontalStackLayout Margin="0,0,0,4">
                    <Ellipse WidthRequest="10" HeightRequest="10" Fill="{StaticResource ThemePrimary}" Margin="0,0,8,0" VerticalOptions="Center"/>
                    <Label Text="FRONT DESK COMMAND CENTER" TextColor="{StaticResource ThemePrimary}" FontAttributes="Bold" FontSize="11"/>
                </HorizontalStackLayout>
                <Label Text="Hotel Reservations Hub" FontSize="24" FontAttributes="Bold" TextColor="#0F172A"/>
            </VerticalStackLayout>

            <Border Grid.Column="1" BackgroundColor="#CCFFFFFF" Stroke="#E2E8F0" StrokeShape="RoundRectangle 16" Padding="12,6" VerticalOptions="Center">
                <HorizontalStackLayout>
                    <Label Text="System Link: " FontSize="11" TextColor="#64748B" FontAttributes="Bold"/>
                    <Label Text="Operational" FontSize="11" TextColor="#059669" FontAttributes="Bold"/>
                </HorizontalStackLayout>
            </Border>
        </Grid>

        <!-- ================= VIEW CONTENT ================= -->
        <Border Grid.Row="1" BackgroundColor="#D9FFFFFF" Stroke="#99FFFFFF" StrokeShape="RoundRectangle 20" Padding="16">
            <Grid RowDefinitions="Auto,*">

                <!-- Section Header -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                    <VerticalStackLayout Grid.Column="0">
                        <Label Text="Room Allocator" FontSize="18" FontAttributes="Bold" TextColor="#1E293B"/>
                        <Label Text="Match incoming reservations with live real estate availability." FontSize="11" TextColor="#64748B"/>
                    </VerticalStackLayout>
                    <Border Grid.Column="1" BackgroundColor="#FEF3C7" Stroke="#FDE68A" StrokeShape="RoundRectangle 10" Padding="8,4" VerticalOptions="Center">
                        <Label Text="AWAITING SETUP" FontSize="9" FontAttributes="Bold" TextColor="#B45309"/>
                    </Border>
                </Grid>

                <!-- Allocator Main Grid -->
                <Grid Grid.Row="1" ColumnDefinitions="2*,12,*">

                    <!-- Left: Pending Assignments -->
                    <VerticalStackLayout Grid.Column="0" Spacing="8">
                        <Label Text="Pending Assignments" FontAttributes="Bold" FontSize="14" TextColor="#111827" />

                        <Border BackgroundColor="#FFFFFF" Stroke="#E2E8F0" StrokeShape="RoundRectangle 12" Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Jose Reyes" FontAttributes="Bold" FontSize="18" TextColor="#1E3A8A" />
                                <Label Text="Status: Pending" FontAttributes="Bold" TextColor="#EAB308" />
                                <Label Text="Type: Deluxe" TextColor="#111827" />
                                <Label Text="Check-in: 2026-08-10" TextColor="#111827" />
                                <Label Text="Check-out: 2026-08-13" TextColor="#111827" />
                                <Label Text="Nights Stayed: 3" TextColor="#111827" />
                                <Label Text="Guests: 4" TextColor="#111827" />
                                <Label Text="Total: ₱9,600.00" FontAttributes="Bold" TextColor="#1E3A8A" />
                                <Button Text="Find &amp; Bind Room" BackgroundColor="#0F4C81" TextColor="White" FontAttributes="Bold" FontSize="10" CornerRadius="8" HeightRequest="32" />
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Right: Matching Inventory -->
                    <VerticalStackLayout Grid.Column="2" Spacing="8">
                        <Label Text="Available Matching Inventory" FontAttributes="Bold" FontSize="14" TextColor="#111827" />

                        <Border BackgroundColor="#FFFFFF" Stroke="#E2E8F0" StrokeShape="RoundRectangle 12" Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Room ID 23" FontAttributes="Bold" FontSize="16" TextColor="#111827" />
                                <Label Text="Room Number: 303" TextColor="#111827" />
                                <Label Text="Room Type: Deluxe" TextColor="#111827" />
                                <Label Text="Price: ₱3,200.00" FontAttributes="Bold" TextColor="#111827" />
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </Grid>
            </Grid>
        </Border>

        <!-- ================= BOTTOM NAVIGATION BAR ================= -->
        <Border Grid.Row="2" BackgroundColor="#CCFFFFFF" Stroke="#E2E8F0" StrokeShape="RoundRectangle 16" Padding="4" HorizontalOptions="Center" WidthRequest="400" Margin="0,12,0,0">
            <Grid ColumnDefinitions="*,*,*">
                <Button Grid.Column="0" Text="ALLOCATION" BackgroundColor="#0F4C81" TextColor="White" FontAttributes="Bold" FontSize="11" CornerRadius="12" Margin="2"/>
                <Button Grid.Column="1" Text="STATUS" BackgroundColor="#EAF2F8" TextColor="#0F4C81" FontAttributes="Bold" FontSize="11" CornerRadius="12" Margin="2" Clicked="NavStatus_Clicked"/>
                <Button Grid.Column="2" Text="REVIEWS" BackgroundColor="#EAF2F8" TextColor="#0F4C81" FontAttributes="Bold" FontSize="11" CornerRadius="12" Margin="2" Clicked="NavReviews_Clicked"/>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
