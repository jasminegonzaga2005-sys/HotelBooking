<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HotelBookingApp.Views.AllocationWindow"
             Title="Allocation Window"
             BackgroundColor="#F5F9FC">

    <ContentPage.Resources>
        <Color x:Key="ThemePrimary">#0F4C81</Color>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto" Margin="16">

        <!-- ================= SYSTEM HEADER ================= -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <VerticalStackLayout Grid.Column="0">
                <HorizontalStackLayout Margin="0,0,0,4">
                    <Ellipse WidthRequest="10" HeightRequest="10" Fill="{StaticResource ThemePrimary}" Margin="0,0,8,0" VerticalOptions="Center"/>
                    <Label Text="FRONT DESK COMMAND CENTER" TextColor="{StaticResource ThemePrimary}" FontAttributes="Bold" FontSize="11"/>
                </HorizontalStackLayout>
                <Label Text="Hotel Reservations Hub" FontSize="24" FontAttributes="Bold" TextColor="#0F172A"/>
            </VerticalStackLayout>

            <Border Grid.Column="1" BackgroundColor="#CCFFFFFF" Stroke="#E2E8F0" StrokeShape="RoundRectangle 16" Padding="12,6" VerticalOptions="Center">
                <HorizontalStackLayout>
                    <Label Text="System Link: " FontSize="11" TextColor="#64748B" FontAttributes="Bold"/>
                    <Label Text="Operational" FontSize="11" TextColor="#059669" FontAttributes="Bold"/>
                </HorizontalStackLayout>
            </Border>
        </Grid>

        <!-- ================= VIEW CONTENT ================= -->
        <Border Grid.Row="1" BackgroundColor="#D9FFFFFF" Stroke="#99FFFFFF" StrokeShape="RoundRectangle 20" Padding="16">
            <Grid RowDefinitions="Auto,*">

                <!-- Section Header -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                    <VerticalStackLayout Grid.Column="0">
                        <Label Text="Room Allocator" FontSize="18" FontAttributes="Bold" TextColor="#1E293B"/>
                        <Label Text="Match incoming reservations with live real estate availability." FontSize="11" TextColor="#64748B"/>
                    </VerticalStackLayout>
                    <Border Grid.Column="1" BackgroundColor="#FEF3C7" Stroke="#FDE68A" StrokeShape="RoundRectangle 10" Padding="8,4" VerticalOptions="Center">
                        <Label Text="AWAITING SETUP" FontSize="9" FontAttributes="Bold" TextColor="#B45309"/>
                    </Border>
                </Grid>

                <!-- Allocator Main Grid -->
                <Grid Grid.Row="1" ColumnDefinitions="2*,12,*">

                    <!-- Left: Pending Assignments -->
                    <VerticalStackLayout Grid.Column="0" Spacing="8">
                        <Label Text="MULTIPLE PENDING ASSIGNMENTS" FontSize="10" FontAttributes="Bold" TextColor="#94A3B8"/>

                        <CollectionView x:Name="PendingGuestsCollectionView">
                            <CollectionView.ItemsLayout>
                                <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="8" VerticalItemSpacing="8"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="#CCFFFFFF" Stroke="#E2E8F0" StrokeShape="RoundRectangle 12" Padding="12">
                                        <VerticalStackLayout Spacing="4">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <Label Text="{Binding Name}" FontAttributes="Bold" TextColor="#0F4C81" FontSize="13"/>
                                                <Label Grid.Column="1" Text="Pending" TextColor="#D97706" FontSize="10" FontAttributes="Bold"/>
                                            </Grid>
                                            <Label Text="{Binding Type, StringFormat='Type: {0} Room'}" FontSize="10" TextColor="#475569"/>
                                            <Label Text="{Binding CheckIn, StringFormat='Check-in: {0}'}" FontSize="10" TextColor="#475569"/>
                                            <Label Text="{Binding CheckOut, StringFormat='Check-out: {0}'}" FontSize="10" TextColor="#475569"/>
                                            <Label Text="{Binding Total, StringFormat='Total: ₱{0:N2}'}" FontSize="10" FontAttributes="Bold" TextColor="#0F4C81" Margin="0,2,0,6"/>

                                            <Button Text="Find &amp; Bind Room" Clicked="OpenAssignModal_Clicked" BackgroundColor="#0F4C81" TextColor="White" FontAttributes="Bold" FontSize="10" CornerRadius="8" HeightRequest="32" Padding="0"/>
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                    <!-- Right: Inventory List -->
                    <Border Grid.Column="2" BackgroundColor="#80FFFFFF" Stroke="#CBD9E6" StrokeShape="RoundRectangle 12" Padding="12">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="MATCHING INVENTORY" FontSize="10" FontAttributes="Bold" TextColor="#94A3B8"/>

                            <CollectionView x:Name="InventoryCollectionView">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border BackgroundColor="White" Stroke="#F1F5F9" StrokeShape="RoundRectangle 8" Padding="8" Margin="0,0,0,6">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <VerticalStackLayout>
                                                    <Label Text="{Binding Code}" FontAttributes="Bold" TextColor="#0F4C81" FontSize="11" FontFamily="OpenSansSemibold"/>
                                                    <Label Text="{Binding Type}" FontSize="9" TextColor="#64748B"/>
                                                </VerticalStackLayout>
                                                <Border Grid.Column="1" BackgroundColor="#ECFDF5" StrokeShape="RoundRectangle 4" Padding="4,2" VerticalOptions="Center">
                                                    <Label Text="{Binding Status}" TextColor="#047857" FontSize="9" FontAttributes="Bold"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- ================= BOTTOM NAVIGATION BAR ================= -->
        <Border Grid.Row="2" BackgroundColor="#CCFFFFFF" Stroke="#E2E8F0" StrokeShape="RoundRectangle 16" Padding="4" HorizontalOptions="Center" WidthRequest="400" Margin="0,12,0,0">
            <Grid ColumnDefinitions="*,*,*">
                <Button Grid.Column="0" Text="ALLOCATION" BackgroundColor="#0F4C81" TextColor="White" FontAttributes="Bold" FontSize="11" CornerRadius="12" Margin="2"/>
                <Button Grid.Column="1" Text="STATUS" BackgroundColor="#EAF2F8" TextColor="#0F4C81" FontAttributes="Bold" FontSize="11" CornerRadius="12" Margin="2" Clicked="NavStatus_Clicked"/>
                <Button Grid.Column="2" Text="REVIEWS" BackgroundColor="#EAF2F8" TextColor="#0F4C81" FontAttributes="Bold" FontSize="11" CornerRadius="12" Margin="2" Clicked="NavReviews_Clicked"/>
            </Grid>
        </Border>
    </Grid>
</ContentPage>