<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="HotelBookingApp.Views.MyBookingsPage"
    BackgroundColor="#F4F8FB"
    Title="My Bookings">

    <Grid RowDefinitions="Auto,*,Auto"
          Padding="20"
          RowSpacing="15">
        <Label
            Grid.Row="0"
            Text="My Bookings"
            FontSize="28"
            FontAttributes="Bold"
            TextColor="#0F4C81" />

        <Frame
            Grid.Row="1"
            BackgroundColor="White"
            CornerRadius="16"
            HasShadow="False"
            BorderColor="#D8E2EC"
            Padding="20">

            <Grid RowDefinitions="*,Auto"
                  RowSpacing="15">

                <ScrollView Grid.Row="0">

                    <VerticalStackLayout Spacing="12">

                        <!-- This must be connected to the actual booking data, for now, we will use placeholders, edit if must-->
                        <!-- I think you need to be able to press on a booking to see the details of that booking, so maybe make the frames clickable and navigate to a new page with the booking details-->
                        <!-- Booking 1 -->
                        <Frame
                            BackgroundColor="#EAF2F8"
                            CornerRadius="12"
                            BorderColor="#D8E2EC"
                            HasShadow="False"
                            HeightRequest="80">

                            <Label
                                Text="Booking 1"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                FontAttributes="Bold"
                                FontSize="16"
                                TextColor="#0F4C81"/>
                        </Frame>

                        <!-- Booking 2 -->
                        <Frame
                            BackgroundColor="#EAF2F8"
                            CornerRadius="12"
                            BorderColor="#D8E2EC"
                            HasShadow="False"
                            HeightRequest="80">

                            <Label
                                Text="Booking 2"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                FontAttributes="Bold"
                                FontSize="16"
                                TextColor="#0F4C81"/>
                        </Frame>

                        <!-- Booking 3 -->
                        <Frame
                            BackgroundColor="#EAF2F8"
                            CornerRadius="12"
                            BorderColor="#D8E2EC"
                            HasShadow="False"
                            HeightRequest="80">

                            <Label
                                Text="Booking 3"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                FontAttributes="Bold"
                                FontSize="16"
                                TextColor="#0F4C81"/>
                        </Frame>

                    </VerticalStackLayout>

                </ScrollView>

                <Grid
                    Grid.Row="1"
                    ColumnDefinitions="*,*"
                    ColumnSpacing="10">

                    <Button
                        Grid.Column="0"
                        Text="Continue to Payment"
                        BackgroundColor="#0F4C81"
                        TextColor="White"
                        CornerRadius="10"
                        HeightRequest="50"/>

                    <Button
                        Grid.Column="1"
                        Text="Cancel Booking"
                        BackgroundColor="#EAF2F8"
                        TextColor="#0F4C81"
                        BorderColor="#0F4C81"
                        BorderWidth="1"
                        CornerRadius="10"
                        HeightRequest="50"/>

                </Grid>

            </Grid>

        </Frame>
        
        <Frame
            Grid.Row="2"
            BackgroundColor="#EAF2F8"
            CornerRadius="16"
            HasShadow="False"
            Padding="12">

            <Grid ColumnDefinitions="*,*,*,*"
                  ColumnSpacing="10">

                <Button
                    Grid.Column="0"
                    Text="Book&#10;Room"
                    HeightRequest="55"
                    CornerRadius="10"
                    BackgroundColor="White"
                    TextColor="#0F4C81"
                    FontSize="12"/>

                <Button
                    Grid.Column="1"
                    Text="My&#10;Bookings"
                    HeightRequest="55"
                    CornerRadius="10"
                    BackgroundColor="#0F4C81"
                    TextColor="White"
                    FontSize="12"/>

                <Button
                    Grid.Column="2"
                    Text="Home"
                    HeightRequest="55"
                    CornerRadius="10"
                    BackgroundColor="White"
                    TextColor="#0F4C81"
                    FontSize="12"/>

                <Button
                    Grid.Column="3"
                    Text="Profile"
                    HeightRequest="55"
                    CornerRadius="10"
                    BackgroundColor="White"
                    TextColor="#0F4C81"
                    FontSize="12"/>

            </Grid>

        </Frame>

    </Grid>

</ContentPage>