<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters="clr-namespace:HotelBookingApp.Converters"
    x:Class="HotelBookingApp.Views.MyBookingsPage"
    BackgroundColor="#F4F8FB"
    Title="My Bookings">


    <ContentPage.Resources>
        <ResourceDictionary>

            <converters:BookingStatusColorConverter
                x:Key="BookingStatusColorConverter"/>

        </ResourceDictionary>
    </ContentPage.Resources>



    <Grid RowDefinitions="Auto,*,Auto"
          Padding="20"
          RowSpacing="15">


        <!-- Title -->
        <Label
            Grid.Row="0"
            Text="My Bookings"
            FontSize="28"
            FontAttributes="Bold"
            TextColor="#0F4C81"/>



        <!-- Booking List -->
        <Frame
            Grid.Row="1"
            BackgroundColor="White"
            CornerRadius="16"
            HasShadow="False"
            BorderColor="#D8E2EC"
            Padding="15">


            <CollectionView
                ItemsSource="{Binding Bookings}"
                SelectedItem="{Binding SelectedBooking}"
                SelectionMode="Single">


                <CollectionView.EmptyView>

                    <Label
                        Text="No bookings found."
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        TextColor="Gray"/>

                </CollectionView.EmptyView>



                <CollectionView.ItemTemplate>

                    <DataTemplate>


                        <Frame
                            Margin="0,5"
                            Padding="15"
                            BackgroundColor="#EAF2F8"
                            CornerRadius="12"
                            BorderColor="#D8E2EC"
                            HasShadow="False">


                            <Grid
                                RowDefinitions="Auto,Auto,Auto,Auto"
                                ColumnDefinitions="*,Auto"
                                RowSpacing="8">



                                <!-- Room -->
                                <Label
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Text="{Binding Room.RoomNum, StringFormat='Room {0}'}"
                                    FontSize="18"
                                    FontAttributes="Bold"
                                    TextColor="#0F4C81"/>



                                <!-- Status -->
                                <Label
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Text="{Binding BookingStatus}"
                                    FontAttributes="Bold"
                                    HorizontalOptions="End"
                                    TextColor="{Binding BookingStatus, 
                                        Converter={StaticResource BookingStatusColorConverter}}"/>





                                <!-- Room Type -->
                                <Label
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Text="{Binding Room.RoomType.RoomTypeName,
                                           StringFormat='Type: {0}'}"
                                    TextColor="#444"/>





                                <!-- Dates -->
                                <VerticalStackLayout
                                    Grid.Row="2"
                                    Grid.ColumnSpan="2"
                                    Spacing="3">


                                    <Label
                                        Text="{Binding CheckIn,
                                            StringFormat='Check-in: {0:MMMM dd, yyyy}'}"
                                        TextColor="#444"/>


                                    <Label
                                        Text="{Binding CheckOut,
                                            StringFormat='Check-out: {0:MMMM dd, yyyy}'}"
                                        TextColor="#444"/>


                                </VerticalStackLayout>






                                <!-- Guests and Cost -->
                                <VerticalStackLayout
                                    Grid.Row="3"
                                    Grid.ColumnSpan="2"
                                    Spacing="3">


                                    <Label
                                        Text="{Binding NumberOfGuests,
                                            StringFormat='Guests: {0}'}"
                                        TextColor="#444"/>


                                    <Label
                                        Text="{Binding TotalCost,
                                            StringFormat='Total: ₱{0:N2}'}"
                                        FontAttributes="Bold"
                                        TextColor="#0F4C81"/>


                                </VerticalStackLayout>



                            </Grid>


                        </Frame>


                    </DataTemplate>


                </CollectionView.ItemTemplate>


            </CollectionView>


        </Frame>





        <!-- Bottom Buttons -->
        <Grid
            Grid.Row="2"
            ColumnDefinitions="*,*"
            ColumnSpacing="10">


            <Button
                Grid.Column="0"
                Text="Continue to Payment"
                Clicked="ContinuePayment_Clicked"
                BackgroundColor="#0F4C81"
                TextColor="White"
                CornerRadius="10"
                HeightRequest="50"/>



            <Button
                Grid.Column="1"
                Text="Cancel Booking"
                Clicked="CancelBooking_Clicked"
                BackgroundColor="#EAF2F8"
                TextColor="#0F4C81"
                BorderColor="#0F4C81"
                BorderWidth="1"
                CornerRadius="10"
                HeightRequest="50"/>


        </Grid>



    </Grid>


</ContentPage>