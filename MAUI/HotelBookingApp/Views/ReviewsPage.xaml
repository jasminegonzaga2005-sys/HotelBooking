<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HotelBookingApp.Views.ReviewsPage"
             Title="Reviews Page"
             BackgroundColor="#F5F9FC">

    <ContentPage.Resources>
        <Color x:Key="ThemePrimary">#0F4C81</Color>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto" Margin="16">

        <!-- ================= HEADER ================= -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <VerticalStackLayout Grid.Column="0">
                <HorizontalStackLayout Margin="0,0,0,4">
                    <Ellipse WidthRequest="10" HeightRequest="10" Fill="{StaticResource ThemePrimary}" Margin="0,0,8,0" VerticalOptions="Center"/>
                    <Label Text="FRONT DESK COMMAND CENTER" TextColor="{StaticResource ThemePrimary}" FontAttributes="Bold" FontSize="11"/>
                </HorizontalStackLayout>
                <Label Text="Hotel Reservations Hub" FontSize="24" FontAttributes="Bold" TextColor="#0F172A"/>
            </VerticalStackLayout>

            <Border Grid.Column="1" BackgroundColor="#CCFFFFFF" Stroke="#E2E8F0" StrokeShape="RoundRectangle 16" Padding="12,6" VerticalOptions="Center">
                <HorizontalStackLayout>
                    <Label Text="System Link: " FontSize="11" TextColor="#64748B" FontAttributes="Bold"/>
                    <Label Text="Operational" FontSize="11" TextColor="#059669" FontAttributes="Bold"/>
                </HorizontalStackLayout>
            </Border>
        </Grid>

        <!-- ================= MAIN CONTENT ================= -->
        <Border Grid.Row="1" BackgroundColor="#D9FFFFFF" Stroke="#99FFFFFF" StrokeShape="RoundRectangle 20" Padding="16">
            <VerticalStackLayout Spacing="12">

                <!-- Section Header -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                    <VerticalStackLayout Grid.Column="0">
                        <Label Text="Guest Feedback" FontSize="18" FontAttributes="Bold" TextColor="#1E293B"/>
                        <Label Text="Post-stay reviews submitted by guests, newest first." FontSize="11" TextColor="#64748B"/>
                    </VerticalStackLayout>

                    <Picker Grid.Column="1" Title="Filter Rating" WidthRequest="120" FontSize="11">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>All Ratings</x:String>
                                <x:String>5 Stars</x:String>
                                <x:String>4 Stars</x:String>
                                <x:String>3 Stars</x:String>
                                <x:String>2 Stars &amp; Below</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>
                </Grid>

                <!-- Review Entry 1 -->
                <Border BackgroundColor="#CCFFFFFF" Stroke="#E2E8F0" StrokeShape="RoundRectangle 12" Padding="12">
                    <VerticalStackLayout Spacing="4">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0">
                                <Label Text="Juan Dela Cruz" FontAttributes="Bold" TextColor="#1E293B" FontSize="12"/>
                                <Label Text="Deluxe Room" FontSize="9" TextColor="#94A3B8"/>
                            </VerticalStackLayout>
                            <Border Grid.Column="1" BackgroundColor="#ECFDF5" StrokeShape="RoundRectangle 8" Padding="6,2" VerticalOptions="Start">
                                <Label Text="5 / 5" TextColor="#047857" FontSize="10" FontAttributes="Bold"/>
                            </Border>
                        </Grid>
                        <Label Text="Amazing stay! The staff were very accommodating and the room was spotless." FontSize="10" TextColor="#475569" Margin="0,2,0,0"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Review Entry 2 -->
                <Border BackgroundColor="#CCFFFFFF" Stroke="#E2E8F0" StrokeShape="RoundRectangle 12" Padding="12">
                    <VerticalStackLayout Spacing="4">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0">
                                <Label Text="Maria Santos" FontAttributes="Bold" TextColor="#1E293B" FontSize="12"/>
                                <Label Text="Standard Room" FontSize="9" TextColor="#94A3B8"/>
                            </VerticalStackLayout>
                            <Border Grid.Column="1" BackgroundColor="#FEF3C7" StrokeShape="RoundRectangle 8" Padding="6,2" VerticalOptions="Start">
                                <Label Text="4 / 5" TextColor="#B45309" FontSize="10" FontAttributes="Bold"/>
                            </Border>
                        </Grid>
                        <Label Text="Comfortable room and good service, though breakfast options could be improved." FontSize="10" TextColor="#475569" Margin="0,2,0,0"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Review Entry 3 -->
                <Border BackgroundColor="#CCFFFFFF" Stroke="#E2E8F0" StrokeShape="RoundRectangle 12" Padding="12">
                    <VerticalStackLayout Spacing="4">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0">
                                <Label Text="Jose Reyes" FontAttributes="Bold" TextColor="#1E293B" FontSize="12"/>
                                <Label Text="Suite Room" FontSize="9" TextColor="#94A3B8"/>
                            </VerticalStackLayout>
                            <Border Grid.Column="1" BackgroundColor="#FEE2E2" StrokeShape="RoundRectangle 8" Padding="6,2" VerticalOptions="Start">
                                <Label Text="3 / 5" TextColor="#DC2626" FontSize="10" FontAttributes="Bold"/>
                            </Border>
                        </Grid>
                        <Label Text="The room was spacious, but the air conditioning was a bit noisy at night." FontSize="10" TextColor="#475569" Margin="0,2,0,0"/>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </Border>

        <!-- ================= BOTTOM NAVIGATION ================= -->
        <Border Grid.Row="2" BackgroundColor="#CCFFFFFF" Stroke="#E2E8F0" StrokeShape="RoundRectangle 16" Padding="4" HorizontalOptions="Center" WidthRequest="400" Margin="0,12,0,0">
            <Grid ColumnDefinitions="*,*,*">
                <Button Grid.Column="0" Text="ALLOCATION" BackgroundColor="#EAF2F8" TextColor="#0F4C81" FontAttributes="Bold" FontSize="11" CornerRadius="12" Margin="2" Clicked="NavAllocation_Clicked"/>
                <Button Grid.Column="1" Text="STATUS" BackgroundColor="#EAF2F8" TextColor="#0F4C81" FontAttributes="Bold" FontSize="11" CornerRadius="12" Margin="2" Clicked="NavStatus_Clicked"/>
                <Button Grid.Column="2" Text="REVIEWS" BackgroundColor="#0F4C81" TextColor="White" FontAttributes="Bold" FontSize="11" CornerRadius="12" Margin="2"/>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
