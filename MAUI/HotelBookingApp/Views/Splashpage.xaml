<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HotelBookingApp.Views.Splashpage"
             BackgroundColor="#D6D9DC">
    <!-- Matches body background -->

    <ContentPage.Resources>
        <!-- Color Palette matching your CSS variables -->
        <Color x:Key="BgOuter">#EAF2F8</Color>
        <Color x:Key="CardBg">#FFFFFF</Color>
        <Color x:Key="Primary">#0F4C81</Color>
        <Color x:Key="TextMuted">#7A8B99</Color>
        <Color x:Key="ButtonBg">#0F4C81</Color>
        <Color x:Key="ButtonText">#FFFFFF</Color>
    </ContentPage.Resources>

    <!-- Center the content completely on screen -->
    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="20">

        <!-- Phone Frame -->
        <Border WidthRequest="340"
                BackgroundColor="{StaticResource BgOuter}"
                StrokeShape="RoundRectangle 20"
                StrokeThickness="0"
                Padding="16">
            <Border.Shadow>
                <Shadow Brush="#0F4C81" Offset="0,10" Radius="30" Opacity="0.15"/>
            </Border.Shadow>

            <!-- Card UI Element -->
            <Border BackgroundColor="{StaticResource CardBg}"
                    StrokeShape="RoundRectangle 16"
                    StrokeThickness="0"
                    Padding="24,32"
                    HeightRequest="480">
                <Border.Shadow>
                    <Shadow Brush="#0F4C81" Offset="0,4" Radius="14" Opacity="0.08"/>
                </Border.Shadow>

                <!-- Grid acts as the Flexbox column with space redistribution -->
                <Grid RowDefinitions="Auto, Auto, Auto, *, Auto">

                    <Label Grid.Row="0"
                           Text="HOTEL NAME" 
                           TextColor="{StaticResource Primary}"
                           FontSize="22"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center"
                           CharacterSpacing="0.5"
                           Margin="0,0,0,16"/>

                    <Label Grid.Row="1"
                           Text="Tagline of hotel" 
                           TextColor="{StaticResource Primary}"
                           FontSize="15"
                           HorizontalTextAlignment="Center"
                           Margin="0,0,0,32"/>

                    <Label Grid.Row="2"
                           Text="hotel overview and description" 
                           TextColor="#444444"
                           FontSize="14"
                           LineHeight="1.5"
                           HorizontalTextAlignment="Center"
                           Margin="0,0,0,0"/>

                    <!-- Row 3 is marked '*' which acts as your CSS .spacer -->

                    <!-- Footer Row Container -->
                    <Grid Grid.Row="4" ColumnDefinitions="*, Auto" ColumnSpacing="12" VerticalOptions="End">

                        <Label Grid.Column="0"
                               Text="Click continue to sign up or login to your account" 
                               TextColor="{StaticResource TextMuted}"
                               FontSize="12"
                               LineHeight="1.4"
                               VerticalOptions="Center"/>

                        <Button Grid.Column="1"
                            Text="Continue"
                            Clicked="OnContinueClicked" 
                            BackgroundColor="{StaticResource ButtonBg}"
                            TextColor="{StaticResource ButtonText}"
                            FontSize="13"
                            FontAttributes="Bold"
                            CornerRadius="8"
                            Padding="20,10"
                            HeightRequest="40"
                            VerticalOptions="Center"/>
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </VerticalStackLayout>
</ContentPage>
