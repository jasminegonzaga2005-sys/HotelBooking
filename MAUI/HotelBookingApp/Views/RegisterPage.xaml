<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="HotelBookingApp.Views.RegisterPage"
    Title="Create Account"
    BackgroundColor="#F4F8FB">

    <ScrollView>

        <VerticalStackLayout
            Padding="30"
            Spacing="20">

            <!-- Title -->
            <Label
                Text="Create Account"
                FontSize="30"
                FontAttributes="Bold"
                TextColor="#0F4C81"/>

            <Label
                Text="Register to start booking your stay."
                FontSize="14"
                TextColor="Gray"/>

            <!-- Card -->
            <Frame
                BackgroundColor="White"
                CornerRadius="18"
                BorderColor="#D8E2EC"
                HasShadow="False"
                Padding="25">

                <VerticalStackLayout Spacing="18">

                    <!-- First Name -->
                    <VerticalStackLayout>
                        <Label
                            Text="First Name"
                            FontAttributes="Bold"
                            TextColor="#0F4C81"/>

                        <Entry
                            x:Name="FirstNameEntry"
                            Placeholder="Juan"
                            BackgroundColor="#F4F8FB"/>
                    </VerticalStackLayout>

                    <!-- Last Name -->
                    <VerticalStackLayout>
                        <Label
                            Text="Last Name"
                            FontAttributes="Bold"
                            TextColor="#0F4C81"/>

                        <Entry
                            x:Name="LastNameEntry"
                            Placeholder="Dela Cruz"
                            BackgroundColor="#F4F8FB"/>
                    </VerticalStackLayout>

                    <!-- Email -->
                    <VerticalStackLayout>
                        <Label
                            Text="Email Address"
                            FontAttributes="Bold"
                            TextColor="#0F4C81"/>

                        <Entry
                            x:Name="EmailEntry"
                            Placeholder="example@email.com"
                            Keyboard="Email"
                            BackgroundColor="#F4F8FB"/>
                    </VerticalStackLayout>

                    <!-- Phone -->
                    <VerticalStackLayout>
                        <Label
                            Text="Phone Number"
                            FontAttributes="Bold"
                            TextColor="#0F4C81"/>

                        <Entry
                            x:Name="PhoneEntry"
                            Placeholder="09XXXXXXXXX"
                            Keyboard="Telephone"
                            BackgroundColor="#F4F8FB"/>
                    </VerticalStackLayout>

                    <!-- Password -->
                    <VerticalStackLayout>
                        <Label
                            Text="Password"
                            FontAttributes="Bold"
                            TextColor="#0F4C81"/>

                        <Entry
                            x:Name="PasswordEntry"
                            Placeholder="Password"
                            IsPassword="True"
                            BackgroundColor="#F4F8FB"/>
                    </VerticalStackLayout>

                    <!-- Confirm Password -->
                    <VerticalStackLayout>
                        <Label
                            Text="Confirm Password"
                            FontAttributes="Bold"
                            TextColor="#0F4C81"/>

                        <Entry
                            x:Name="ConfirmPasswordEntry"
                            Placeholder="Confirm Password"
                            IsPassword="True"
                            BackgroundColor="#F4F8FB"/>
                    </VerticalStackLayout>

                    <!-- Register Button -->
                    <Button
                        Text="Create Account"
                        BackgroundColor="#0F4C81"
                        TextColor="White"
                        HeightRequest="50"
                        CornerRadius="10"
                        Clicked="Register_Clicked"/>

                    <HorizontalStackLayout
                        HorizontalOptions="Center">

                        <Label
                            Text="Already have an account?"
                            TextColor="Gray"/>

                        <Button
                            Text="Login"
                            BackgroundColor="Transparent"
                            TextColor="#0F4C81"
                            Clicked="Login_Clicked"/>

                    </HorizontalStackLayout>

                </VerticalStackLayout>

            </Frame>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>
