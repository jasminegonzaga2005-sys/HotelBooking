<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="HotelBookingApp.Views.PaymentPage"
    Title="Payment"
    BackgroundColor="#F5F7FA">

    <Grid RowDefinitions="*,Auto">

        <ScrollView>

            <VerticalStackLayout
                Padding="20"
                Spacing="20">

                <Label
                    Text="Payment"
                    FontSize="28"
                    FontAttributes="Bold"
                    TextColor="#0F4C81"/>

                <Frame
                    BackgroundColor="White"
                    CornerRadius="15"
                    HasShadow="False">

                    <VerticalStackLayout
                        Spacing="15">

                        <Label
                            Text="Booking Summary"
                            FontSize="20"
                            FontAttributes="Bold"
                            TextColor="#0F4C81"/>

                        <Frame
                            BackgroundColor="#EAF2F8"
                            CornerRadius="12"
                            HasShadow="False">

                            <VerticalStackLayout
                                Spacing="6">

                                <Label
                                    Text="CURRENT SUMMARY"
                                    FontAttributes="Bold"
                                    FontSize="12"
                                    TextColor="#0F4C81"/>

                                <Label Text="Room: Standard Room"/>
                                <!--need to be able to choose the room type-->
                                <Label Text="Check-in: --/--/----"/>
                                <!--need to be able to type or choose date-->
                                <Label Text="Check-out: --/--/----"/>
                                <!--need to be able to type or choose date-->
                                <Label Text="Guests: 2"/>
                                <!--need to be able to match the allowed number of guests for the room type-->

                            </VerticalStackLayout>

                        </Frame>

                        <BoxView
                            HeightRequest="1"
                            BackgroundColor="LightGray"/>

                        <Label
                            Text="TOTAL AMOUNT"
                            HorizontalOptions="Center"
                            FontAttributes="Bold"
                            TextColor="#0F4C81"/>

                        <Label
                            Text="₱0.00" 
                            FontSize="28"
                            FontAttributes="Bold"
                            HorizontalOptions="Center"
                            TextColor="#0F4C81"/>
                        <!-- need to be able to calculate total amount based on room type, number of nights -->

                        <Grid
                            ColumnDefinitions="*,*"
                            ColumnSpacing="10">

                            <Button
                                Grid.Column="0"
                                Text="Pay"
                                BackgroundColor="#0F4C81"
                                TextColor="White"
                                HeightRequest="50"
                                CornerRadius="10"
                                Clicked="Pay_Clicked"/>

                            <Button
                                Grid.Column="1"
                                Text="Cancel"
                                BackgroundColor="#EAF2F8"
                                TextColor="#0F4C81"
                                HeightRequest="50"
                                CornerRadius="10"
                                Clicked="Cancel_Clicked"/>

                        </Grid>

                    </VerticalStackLayout>

                </Frame>

            </VerticalStackLayout>

        </ScrollView>

        <Frame
            Grid.Row="1"
            BackgroundColor="#EAF2F8"
            CornerRadius="16"
            Padding="15"
            HasShadow="False">

            <Grid
                ColumnDefinitions="*,*,*,*"
                ColumnSpacing="10">

                <Button
                    Grid.Column="0"
                    Text="Book&#10;Room"
                    HeightRequest="60"/>

                <Button
                    Grid.Column="1"
                    Text="My&#10;Bookings"
                    HeightRequest="60"/>

                <Button
                    Grid.Column="2"
                    Text="Home"
                    HeightRequest="60"/>

                <Button
                    Grid.Column="3"
                    Text="Profile"
                    HeightRequest="60"/>

            </Grid>

        </Frame>

    </Grid>

</ContentPage>