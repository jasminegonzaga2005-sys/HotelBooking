<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="HotelBookingApp.Views.PaymentPage"
    Title="Payment"
    BackgroundColor="#F5F7FA">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">

            <VerticalStackLayout
                Padding="20"
                Spacing="20">

                <Label
                    Text="Payment"
                    FontSize="28"
                    FontAttributes="Bold"
                    TextColor="#0F4C81"/>


                <Frame
                    BackgroundColor="White"
                    CornerRadius="15"
                    HasShadow="False"
                    Padding="20">

                    <VerticalStackLayout
                        Spacing="15">


                        <Label
                            Text="Booking Summary"
                            FontSize="20"
                            FontAttributes="Bold"
                            TextColor="#0F4C81"/>



                        <Frame
                            BackgroundColor="#EAF2F8"
                            CornerRadius="12"
                            HasShadow="False"
                            Padding="15">


                            <VerticalStackLayout
                                Spacing="8">


                                <Label
                                    Text="CURRENT SUMMARY"
                                    FontAttributes="Bold"
                                    FontSize="12"
                                    TextColor="#0F4C81"/>


                                <Label
                                    x:Name="RoomLabel"
                                    Text="Room:"
                                    TextColor="#444"/>


                                <Label
                                    x:Name="CheckInLabel"
                                    Text="Check-in:"
                                    TextColor="#444"/>


                                <Label
                                    x:Name="CheckOutLabel"
                                    Text="Check-out:"
                                    TextColor="#444"/>


                                <Label
                                    x:Name="GuestsLabel"
                                    Text="Guests:"
                                    TextColor="#444"/>


                            </VerticalStackLayout>


                        </Frame>



                        <BoxView
                            HeightRequest="1"
                            BackgroundColor="LightGray"/>



                        <Label
                            Text="TOTAL AMOUNT"
                            HorizontalOptions="Center"
                            FontAttributes="Bold"
                            TextColor="#0F4C81"/>


                        <Label
                            x:Name="TotalLabel"
                            Text="₱0.00"
                            FontSize="28"
                            FontAttributes="Bold"
                            HorizontalOptions="Center"
                            TextColor="#0F4C81"/>



                        <Grid
                            ColumnDefinitions="*,*"
                            ColumnSpacing="10">


                            <Button
                                Grid.Column="0"
                                Text="Pay"
                                BackgroundColor="#0F4C81"
                                TextColor="White"
                                HeightRequest="50"
                                CornerRadius="10"
                                Clicked="Pay_Clicked"/>


                            <Button
                                Grid.Column="1"
                                Text="Cancel"
                                BackgroundColor="#EAF2F8"
                                TextColor="#0F4C81"
                                HeightRequest="50"
                                CornerRadius="10"
                                Clicked="Cancel_Clicked"/>


                        </Grid>


                    </VerticalStackLayout>


                </Frame>


            </VerticalStackLayout>


        </ScrollView>

    </Grid>


</ContentPage>